{
  "name": "devtools-tracing",
  "version": "1.1.1",
  "description": "Utilities for working with trace files",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --emitDeclarationOnly || true; esbuild index.ts --bundle --platform=node --outfile=dist/index.js --format=cjs",
    "generate": "tsx generate.ts",
    "example:inp": "tsx examples/inp.ts",
    "example:stats": "tsx examples/stats.ts",
    "size": "du -sh dist/",
    "prepublishOnly": "npm run generate && npm run build"
  },
  "author": "Samuel Maddock <sam@samuelmaddock.com>",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/samuelmaddock/devtools-tracing.git"
  },
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@typescript-eslint/typescript-estree": "^8.46.2",
    "chrome-devtools-frontend": "^1.0.1603822",
    "esbuild": "^0.27.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "tabWidth": 2,
    "singleQuote": true
  }
}
